    def show_histogram(self) -> None:
        """Display wait time histogram."""
        if not self.data_manager.wait_times:
            messagebox.showwarning("No Data", "Run simulation first!")
            return
        
        if not MATPLOTLIB_AVAILABLE:
            messagebox.showerror("Error", "Matplotlib not installed!")
            return
        
        # Clear previous canvas
        for widget in self.graph_canvas_frame.winfo_children():
            widget.destroy()
        
        fig = GraphingModule.create_wait_time_histogram(
            self.data_manager.wait_times
        )
        canvas = FigureCanvasTkAgg(fig, master=self.graph_canvas_frame)
        canvas.draw()
        canvas.get_tk_widget().pack(fill="both", expand=True)
    
    def show_cdf(self) -> None:
