def go_to_movies(env: simpy.Environment, moviegoer_id: int,
                theater: Theater, data_manager: SimulationDataManager) -> None:
    """
    Simulate a moviegoer's journey through the theater.
    
    Algorithm: Queue-based service processing with state tracking
    - Time Complexity: O(1) for each service transition
    - Each moviegoer processes through sequential stations
    - Food purchase is probabilistic (50% probability)
    
    Args:
        env: SimPy environment
        moviegoer_id: Moviegoer identifier
        theater: Theater instance with resources
        data_manager: Data persistence manager
        
    Raises:
        SimulationException: If processing fails
    """
    arrival_time = env.now
    
    try:
        # Stage 1: Purchase ticket (FIFO queue at cashier)
        with theater.cashier.request() as request:
            yield request
            yield env.process(theater.purchase_ticket(moviegoer_id))
        
        # Stage 2: Verify ticket (sequential with usher)
        with theater.usher.request() as request:
            yield request
            yield env.process(theater.check_ticket(moviegoer_id))
        
        # Stage 3: Optional food purchase (probabilistic)
        if random.random() < 0.50:  # 50% probability
            with theater.server.request() as request:
                yield request
                yield env.process(theater.sell_food(moviegoer_id))
        
        # Calculate total wait time from arrival to completion
        total_wait_time = env.now - arrival_time
        data_manager.add_wait_time(total_wait_time)
        theater.moviegoers_processed += 1
        theater.total_wait_time += total_wait_time
    
    except Exception as e:
        raise SimulationException(
            f"Error processing moviegoer {moviegoer_id}: {str(e)}"
        )


def run_theater(env: simpy.Environment, num_cashiers: int, num_servers: int,
               num_ushers: int, moviegoer_count: int,
               update_callback: Callable, data_manager: SimulationDataManager) -> None:
    """
    Main simulation loop managing moviegoer arrivals.
    
    Algorithm: Discrete Event Simulation (DES) with exponential inter-arrival times
    - Time Complexity: O(n log n) where n = number of moviegoers
      (dominated by scheduling n events in priority queue)
    - Arrivals are staggered using exponential distribution (realistic)
    - Events are processed in chronological order by SimPy scheduler
    
    Args:
        env: SimPy environment
        num_cashiers: Number of cashiers
        num_servers: Number of food servers
        num_ushers: Number of ushers
        moviegoer_count: Total moviegoers to simulate
        update_callback: Function to update UI
        data_manager: Data persistence manager
        
    Raises:
        SimulationException: If initialization fails
    """
    try:
        theater = Theater(env, num_cashiers, num_servers, num_ushers)
    except ConfigurationException as e:
        raise SimulationException(f"Theater initialization failed: {str(e)}")
    
    # Generate initial batch of moviegoers (immediate arrival)
    for moviegoer_id in range(min(3, moviegoer_count)):
        env.process(go_to_movies(env, moviegoer_id, theater, data_manager))
    
    # Generate remaining moviegoers with exponential inter-arrival times
    # Lambda = 1/0.2 (5 moviegoers per time unit on average)
    moviegoer_id = 3
    while moviegoer_id < moviegoer_count:
        # Exponential inter-arrival time (more realistic than fixed intervals)
        inter_arrival_time = random.expovariate(1 / 0.20)
        yield env.timeout(inter_arrival_time)
        
        env.process(go_to_movies(env, moviegoer_id, theater, data_manager))
        update_callback(moviegoer_id + 1, env.now)
        moviegoer_id += 1


