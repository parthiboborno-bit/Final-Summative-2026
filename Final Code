class SimulationDataManager:
    """
    Manages persistence of simulation data to JSON and CSV files.
    
    Implements robust I/O handling with comprehensive error checking.
    Supports multiple export formats for data analysis.
    """
    
    def __init__(self, base_filename: str = "simulation_results"):
        """
        Initialize data manager.
        
        Args:
            base_filename: Base name for output files (without extension)
        """
        self.base_filename = base_filename
        self.wait_times: List[float] = []
        self.service_breakdown: Dict[str, List[float]] = defaultdict(list)
        self.simulation_history: List[Dict] = []
        self.current_config: Optional[Dict] = None
    
    def add_wait_time(self, wait_time: float) -> None:
        """Add a wait time to the collection."""
        if wait_time < 0:
            raise DataPersistenceException("Wait time cannot be negative")
        self.wait_times.append(wait_time)
    
    def add_service_time(self, service_type: str, duration: float) -> None:
        """Record service time breakdown."""
        self.service_breakdown[service_type].append(duration)
    
    def clear(self) -> None:
        """Clear all simulation data."""
        self.wait_times.clear()
        self.service_breakdown.clear()
        self.simulation_history.clear()
    
    def save_json_results(self, config: Dict, avg_wait: Tuple[int, int],
                         additional_stats: Dict = None) -> str:
        """
        Save simulation results to JSON file.
        
        Args:
            config: Configuration dictionary with resource counts
            avg_wait: Tuple of (minutes, seconds)
            additional_stats: Optional additional statistics
            
        Returns:
            Path to saved file
            
        Raises:
            DataPersistenceException: If file I/O fails
        """
        try:
            # Compute comprehensive statistics
            stats = self._compute_statistics(config)
            stats.update(additional_stats or {})
            
            results = {
                "timestamp": datetime.now().isoformat(),
                "configuration": config,
                "average_wait_time": {
                    "minutes": avg_wait[0],
                    "seconds": avg_wait[1],
                    "total_seconds": avg_wait[0] * 60 + avg_wait[1]
                },
                "statistics": stats,
                "all_wait_times": self.wait_times,
                "total_moviegoers": len(self.wait_times)
            }
            
            filepath = f"{self.base_filename}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
            with open(filepath, 'w') as f:
                json.dump(results, f, indent=4)
            
            self.simulation_history.append(results)
            return filepath
        
        except IOError as e:
            raise DataPersistenceException(
                f"Failed to save JSON results: {str(e)}"
            )
    
    def save_csv_results(self, config: Dict) -> str:
        """
        Save detailed wait times to CSV for analysis.
        
        Args:
            config: Configuration dictionary
            
        Returns:
            Path to saved file
            
        Raises:
            DataPersistenceException: If file I/O fails
        """
        try:
            filepath = f"{self.base_filename}_detailed_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
            
            with open(filepath, 'w', newline='') as f:
                writer = csv.writer(f)
                writer.writerow([
                    "Moviegoer_ID", "Wait_Time_Minutes", "Configuration",
                    "Timestamp"
                ])
                
                for idx, wait_time in enumerate(self.wait_times, 1):
                    writer.writerow([
                        idx,
                        round(wait_time, 2),
                        f"C:{config['cashiers']}_S:{config['servers']}_U:{config['ushers']}",
                        datetime.now().isoformat()
                    ])
            
            return filepath
        
        except IOError as e:
            raise DataPersistenceException(
                f"Failed to save CSV results: {str(e)}"
            )
    
    def _compute_statistics(self, config: Dict) -> Dict:
        """
        Compute comprehensive statistics from wait times.
        
        Time Complexity: O(n) for mean, median, and std dev calculations
        
        Returns:
            Dictionary with statistical measures
        """
        if not self.wait_times:
            return {
                "min_wait": 0, "max_wait": 0, "mean_wait": 0,
                "median_wait": 0, "std_dev": 0, "percentile_95": 0
            }
        
        sorted_times = sorted(self.wait_times)
        return {
            "min_wait": round(min(self.wait_times), 2),
            "max_wait": round(max(self.wait_times), 2),
            "mean_wait": round(statistics.mean(self.wait_times), 2),
            "median_wait": round(statistics.median(self.wait_times), 2),
            "std_dev": round(statistics.stdev(self.wait_times), 2) if len(self.wait_times) > 1 else 0,
            "percentile_95": round(sorted_times[int(len(sorted_times) * 0.95)], 2)
        }


