class Theater:
    """
    Represents a movie theater with multiple service stations.
    
    Implements resource management using SimPy's Resource abstraction.
    Encapsulates all theater operations and services.
    """
    
    def __init__(self, env: simpy.Environment, num_cashiers: int,
                 num_servers: int, num_ushers: int):
        """
        Initialize theater with specified resources.
        
        Args:
            env: SimPy environment
            num_cashiers: Number of cashier resources
            num_servers: Number of food server resources
            num_ushers: Number of usher resources
            
        Raises:
            ConfigurationException: If any resource count is non-positive
        """
        # Validate resource configuration
        if any(x <= 0 for x in [num_cashiers, num_servers, num_ushers]):
            raise ConfigurationException(
                "All resources must have positive counts"
            )
        
        self.env = env
        self.num_cashiers = num_cashiers
        self.num_servers = num_servers
        self.num_ushers = num_ushers
        
        # Initialize resources using SimPy's queue-based Resource
        self.cashier = simpy.Resource(env, num_cashiers)
        self.server = simpy.Resource(env, num_servers)
        self.usher = simpy.Resource(env, num_ushers)
        
        # Initialize services using polymorphism
        self.ticket_purchase = TicketPurchase(env)
        self.ticket_check = TicketCheck(env)
        self.food_service = FoodService(env)
        
        # Statistics tracking
        self.moviegoers_processed = 0
        self.total_wait_time = 0.0
    
    def purchase_ticket(self, moviegoer_id: int) -> None:
        """Process ticket purchase through cashier."""
        yield self.env.process(self.ticket_purchase.process(moviegoer_id))
    
    def check_ticket(self, moviegoer_id: int) -> None:
        """Process ticket verification through usher."""
        yield self.env.process(self.ticket_check.process(moviegoer_id))
    
    def sell_food(self, moviegoer_id: int) -> None:
        """Process food service through concession."""
        yield self.env.process(self.food_service.process(moviegoer_id))


