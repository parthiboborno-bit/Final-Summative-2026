    def clear_results(self) -> None:
        """Clear all results and reset to defaults."""
        for key in self.input_vars:
            if key == "moviegoers":
                self.input_vars[key].set("50")
            else:
                self.input_vars[key].set("2")
        
        self.moviegoers_label.config(text="0")
        self.time_label.config(text="0.00 min")
        self.result_label.config(text="")
        self.status_label.config(text="Ready")
        self.stats_text.delete(1.0, tk.END)
        self.data_manager.clear()
        
        # Clear graphs
        for widget in self.graph_canvas_frame.winfo_children():
            widget.destroy()


