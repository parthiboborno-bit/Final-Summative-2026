                  command=self.show_histogram).pack(side="left", padx=5)
        ttk.Button(graph_controls, text="📉 Cumulative Distribution",
                  command=self.show_cdf).pack(side="left", padx=5)
        
        self.graph_canvas_frame = ttk.Frame(self.graphs_frame)
        self.graph_canvas_frame.pack(padx=10, pady=10, fill="both", expand=True)
    
    def _validate_inputs(self) -> Tuple[bool, str, Dict]:
        """
        Validate user input with comprehensive error handling.
        
        Returns:
            Tuple of (is_valid, error_message, parsed_values)
        """
        try:
            values = {}
            for key, var in self.input_vars.items():
                value = int(var.get())
                values[key] = value
            
            # Validate positive values
            for key, value in values.items():
                if value <= 0:
                    return False, f"{key.capitalize()} must be positive!", {}
            
            # Reasonable upper limits for simulation
            if values['moviegoers'] > 1000:
                return False, "Maximum 1000 moviegoers for simulation!", {}
            
            return True, "", values
        
        except ValueError:
            return False, "Please enter valid integers!", {}
    
    def run_simulation(self) -> None:
        """Run simulation with error handling and user feedback."""
        if self.simulation_running:
            messagebox.showwarning("Warning", "Simulation is already running!")
            return
        
        is_valid, error_msg, values = self._validate_inputs()
        if not is_valid:
            messagebox.showerror("Validation Error", error_msg)
            return
        
        self.simulation_running = True
        self.run_button.config(state="disabled")
        self.status_label.config(text="Running...", foreground="orange")
        self.result_label.config(text="Simulation in progress...")
        
        # Run simulation in separate thread
        thread = threading.Thread(
            target=self._simulation_worker,
            args=(values['cashiers'], values['servers'],
                  values['ushers'], values['moviegoers']),
            daemon=True
        )
        thread.start()
    
    def _simulation_worker(self, num_cashiers: int, num_servers: int,
                          num_ushers: int, num_moviegoers: int) -> None:
        """
        Worker thread for running simulation.
        
        Implements discrete event simulation with comprehensive error handling.
        """
        try:
            self.data_manager.clear()
            random.seed(42)  # Reproducible results
            
            env = simpy.Environment()
            env.process(run_theater(env, num_cashiers, num_servers,
                                   num_ushers, num_moviegoers,
                                   self.update_status, self.data_manager))
            env.run(until=500)  # Extended simulation time
            
            # Calculate statistics
            mins, secs = calculate_statistics(self.data_manager.wait_times)
            result_text = f"{mins} min {secs} sec"
            
            config = {
                'cashiers': num_cashiers,
                'servers': num_servers,
                'ushers': num_ushers,
                'moviegoers': num_moviegoers
            }
            self.config_history.append((config, mins + secs / 60))
            
            self.root.after(0, self._display_results, result_text, config)
        
        except (SimulationException, TheaterException) as e:
            self.root.after(0, lambda: messagebox.showerror(
                "Simulation Error", str(e)
            ))
            self.root.after(0, self._reset_simulation)
        except Exception as e:
            self.root.after(0, lambda: messagebox.showerror(
                "Unexpected Error", str(e)
            ))
            self.root.after(0, self._reset_simulation)
    
    def _display_results(self, result_text: str, config: Dict) -> None:
        """Display results with detailed statistics."""
        self.result_label.config(text=result_text, foreground="darkgreen")
        self.status_label.config(text="Complete", foreground="green")
        
        # Display detailed statistics
        stats = self.data_manager._compute_statistics(config)
        stats_text = self._format_statistics(stats, config)
        self.stats_text.delete(1.0, tk.END)
        self.stats_text.insert(tk.END, stats_text)
        
        self._reset_simulation()
    
    def _format_statistics(self, stats: Dict, config: Dict) -> str:
        """Format statistics for display."""
        text = f"""
Configuration:
  Cashiers: {config['cashiers']}
  Servers: {config['servers']}
  Ushers: {config['ushers']}
  Total Moviegoers: {config['moviegoers']}

Statistics:
  Total Wait Times Recorded: {len(self.data_manager.wait_times)}
  Minimum Wait Time: {stats['min_wait']} min
  Maximum Wait Time: {stats['max_wait']} min
  Mean (Average): {stats['mean_wait']} min
  Median: {stats['median_wait']} min
  Standard Deviation: {stats['std_dev']} min
  95th Percentile: {stats['percentile_95']} min

Analysis:
  Configuration provides good load balancing if mean wait time < 5 min
  Standard deviation indicates variability in service times
  95th percentile shows worst-case scenario for most customers
        """
        return text
    
    def update_status(self, moviegoer_count: int, sim_time: float) -> None:
        """Update GUI with simulation progress."""
        self.moviegoers_label.config(text=str(moviegoer_count))
        self.time_label.config(text=f"{sim_time:.2f} min")
        self.root.update_idletasks()
    
    def _reset_simulation(self) -> None:
        """Reset simulation state."""
        self.simulation_running = False
        self.run_button.config(state="normal")
    
    def save_json_results(self) -> None:
        """Save current results to JSON file."""
        if not self.data_manager.wait_times:
            messagebox.showwarning("No Data", "Run simulation first!")
            return
        
        try:
            is_valid, error_msg, values = self._validate_inputs()
            if not is_valid:
                return
            
            mins, secs = calculate_statistics(self.data_manager.wait_times)
            config = {
                'cashiers': values['cashiers'],
                'servers': values['servers'],
                'ushers': values['ushers'],
                'moviegoers': values['moviegoers']
            }
            
            filepath = self.data_manager.save_json_results(
                config, (mins, secs)
            )
            messagebox.showinfo("Success", f"Saved to: {filepath}")
        
        except DataPersistenceException as e:
            messagebox.showerror("Save Error", str(e))
    
    def save_csv_results(self) -> None:
        """Save detailed results to CSV."""
        if not self.data_manager.wait_times:
            messagebox.showwarning("No Data", "Run simulation first!")
            return
        
        try:
            is_valid, _, values = self._validate_inputs()
            if not is_valid:
                return
            
            config = {
                'cashiers': values['cashiers'],
                'servers': values['servers'],
                'ushers': values['ushers']
            }
            
            filepath = self.data_manager.save_csv_results(config)
            messagebox.showinfo("Success", f"Saved to: {filepath}")
        
        except DataPersistenceException as e:
