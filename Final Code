def calculate_statistics(wait_times: List[float]) -> Tuple[int, int]:
    """
    Calculate average wait time from collected data.
    
    Algorithm: Statistical Analysis
    - Time Complexity: O(n) for mean calculation
    - Uses Python's statistics module for robustness
    
    Args:
        wait_times: List of individual wait times
    
    Returns:
        Tuple of (minutes, seconds) rounded
        
    Raises:
        SimulationException: If statistical calculation fails
    """
    if not wait_times:
        return 0, 0
    
    try:
        average_wait = statistics.mean(wait_times)
        minutes = int(average_wait)
        seconds = int((average_wait - minutes) * 60)
        return minutes, seconds
    except Exception as e:
        raise SimulationException(f"Statistical calculation failed: {str(e)}")


