class TheaterException(Exception):
    """Base custom exception for theater simulation errors."""
    pass


class ConfigurationException(TheaterException):
    """Raised when configuration is invalid."""
    pass


class SimulationException(TheaterException):
    """Raised when simulation encounters errors during execution."""
    pass


class DataPersistenceException(TheaterException):
    """Raised when file I/O operations fail."""
    pass


