class TheaterService(ABC):
    """
    Abstract base class for theater services using inheritance and polymorphism.
    
    This class demonstrates the Strategy pattern and Template Method pattern,
    enabling flexible service implementation and extension.
    """
    
    def __init__(self, env: simpy.Environment, duration_range: Tuple[float, float],
                 service_name: str):
        """
        Initialize a theater service.
        
        Args:
            env: SimPy environment
            duration_range: Tuple of (min, max) duration in time units
            service_name: Human-readable service identifier
            
        Raises:
            ConfigurationException: If duration_range is invalid
        """
        if duration_range[0] < 0 or duration_range[1] < duration_range[0]:
            raise ConfigurationException(
                f"Invalid duration range for {service_name}: {duration_range}"
            )
        
        self.env = env
        self.duration_range = duration_range
        self.service_name = service_name
        self.service_times: List[float] = []
    
    @abstractmethod
    def process(self, moviegoer_id: int) -> None:
        """
        Abstract method for processing a moviegoer.
        
        Implements the Template Method pattern - subclasses define
        specific processing logic.
        """
        pass
    
    def record_service_time(self, duration: float) -> None:
        """Record service time for analytics."""
        self.service_times.append(duration)
    
    def get_average_service_time(self) -> float:
        """Calculate average service time using O(1) amortized complexity."""
        if not self.service_times:
            return 0.0
        return statistics.mean(self.service_times)


class TicketPurchase(TheaterService):
    """Represents ticket purchase service (1-3 minutes)."""
    
    def __init__(self, env: simpy.Environment):
        """Initialize ticket purchase service."""
        super().__init__(env, (1, 3), "TicketPurchase")
    
    def process(self, moviegoer_id: int) -> None:
        """Process ticket purchase with variable duration."""
        duration = random.uniform(*self.duration_range)
        self.record_service_time(duration)
        yield self.env.timeout(duration)


class TicketCheck(TheaterService):
    """Represents ticket verification service (3 seconds fixed)."""
    
    def __init__(self, env: simpy.Environment):
        """Initialize ticket check service."""
        super().__init__(env, (0.05, 0.05), "TicketCheck")
    
    def process(self, moviegoer_id: int) -> None:
        """Process ticket verification with fixed duration."""
        duration = 3 / 60  # 3 seconds in minutes
        self.record_service_time(duration)
        yield self.env.timeout(duration)


class FoodService(TheaterService):
    """Represents concession food service (1-5 minutes)."""
    
    def __init__(self, env: simpy.Environment):
        """Initialize food service."""
        super().__init__(env, (1, 5), "FoodService")
    
    def process(self, moviegoer_id: int) -> None:
        """Process food purchase with variable duration."""
        duration = random.uniform(*self.duration_range)
        self.record_service_time(duration)
        yield self.env.timeout(duration)


