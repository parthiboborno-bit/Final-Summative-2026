import simpy
import random
import statistics
import pygame
import sys
from enum import Enum

# Initialize Pygame
pygame.init()

# Colors
BLACK = (0, 0, 0)
WHITE = (255, 255, 255)
GRAY = (128, 128, 128)
LIGHT_GRAY = (200, 200, 200)
BLUE = (50, 150, 255)
GREEN = (50, 255, 100)
RED = (255, 50, 50)
YELLOW = (255, 255, 0)
DARK_GREEN = (34, 139, 34)

# Screen dimensions
SCREEN_WIDTH = 1400
SCREEN_HEIGHT = 800
FPS = 60

class MoviegoerState(Enum):
    WAITING_AT_CASHIER = 1
    BUYING_TICKET = 2
    WAITING_AT_USHER = 3
    CHECKING_TICKET = 4
    WAITING_AT_SERVER = 5
    BUYING_FOOD = 6
    DONE = 7

class Moviegoer:
    def __init__(self, id, env):
        self.id = id
        self.env = env
        self.state = MoviegoerState.WAITING_AT_CASHIER
        self.arrival_time = env.now
        self.start_time = env.now
        self.x = 0
        self.y = 0
        self.buying_food = False
        self.wait_time = 0

class Theater(object):
    def __init__(self, env, num_cashiers, num_servers, num_ushers):
        self.env = env
        self.cashier = simpy.Resource(env, num_cashiers)
        self.server = simpy.Resource(env, num_servers)
        self.usher = simpy.Resource(env, num_ushers)
        self.moviegoers = []

    def purchase_ticket(self, moviegoer):
        yield self.env.timeout(random.randint(1, 3))

    def check_ticket(self, moviegoer):
        yield self.env.timeout(3 / 60)

    def sell_food(self, moviegoer):
        yield self.env.timeout(random.randint(1, 5))

class SimulationVisualizer:
    def __init__(self, width, height):
        self.screen = pygame.display.set_mode((width, height))
        pygame.display.set_caption("Theater Simulation")
        self.clock = pygame.time.Clock()
        self.font_large = pygame.font.Font(None, 36)
        self.font_medium = pygame.font.Font(None, 24)
        self.font_small = pygame.font.Font(None, 18)
        self.wait_times = []
        self.current_time = 0
        self.total_moviegoers = 0
        self.simulation_running = True

    def draw_text(self, text, font, color, x, y):
        surface = font.render(text, True, color)
        self.screen.blit(surface, (x, y))

    def draw_station(self, x, y, width, height, label, count, queue_size):
        pygame.draw.rect(self.screen, LIGHT_GRAY, (x, y, width, height))
        pygame.draw.rect(self.screen, BLACK, (x, y, width, height), 2)
        self.draw_text(label, self.font_medium, BLACK, x + 10, y + 10)
        self.draw_text(f"Staff: {count}", self.font_small, BLACK, x + 10, y + 35)
        self.draw_text(f"Queue: {queue_size}", self.font_small, BLUE, x + 10, y + 55)

    def draw_moviegoer(self, moviegoer, x, y, radius=8):
        color = WHITE
        if moviegoer.state == MoviegoerState.WAITING_AT_CASHIER:
            color = BLUE
        elif moviegoer.state == MoviegoerState.BUYING_TICKET:
            color = YELLOW
        elif moviegoer.state == MoviegoerState.WAITING_AT_USHER:
            color = RED
        elif moviegoer.state == MoviegoerState.CHECKING_TICKET:
            color = YELLOW
        elif moviegoer.state == MoviegoerState.WAITING_AT_SERVER:
            color = GREEN
        elif moviegoer.state == MoviegoerState.BUYING_FOOD:
            color = YELLOW
        elif moviegoer.state == MoviegoerState.DONE:
            color = DARK_GREEN

        pygame.draw.circle(self.screen, color, (int(x), int(y)), radius)
        pygame.draw.circle(self.screen, BLACK, (int(x), int(y)), radius, 1)

    def update_display(self, env, theater, num_cashiers, num_servers, num_ushers):
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                self.simulation_running = False

        self.screen.fill(WHITE)

        # Draw title
        self.draw_text("Theater Simulation", self.font_large, BLACK, 20, 20)
        self.draw_text(f"Simulation Time: {env.now:.2f} min", self.font_medium, BLACK, 20, 60)

        # Draw stations
        self.draw_station(50, 150, 200, 120, "🎫 Cashier", num_cashiers, len(theater.cashier.queue))
        self.draw_station(330, 150, 200, 120, "👤 Usher", num_ushers, len(theater.usher.queue))
        self.draw_station(610, 150, 200, 120, "🍿 Server", num_servers, len(theater.server.queue))

        # Draw statistics panel
        stats_y = 320
        pygame.draw.rect(self.screen, LIGHT_GRAY, (50, stats_y, 760, 200))
        pygame.draw.rect(self.screen, BLACK, (50, stats_y, 760, 200), 2)

        self.draw_text("Statistics", self.font_medium, BLACK, 70, stats_y + 15)
        self.draw_text(f"Total Moviegoers: {self.total_moviegoers}", self.font_small, BLACK, 70, stats_y + 50)

        if self.wait_times:
            avg_wait = statistics.mean(self.wait_times)
            mins, frac_mins = divmod(avg_wait, 1)
            secs = frac_mins * 60
            self.draw_text(f"Avg Wait Time: {int(mins)}m {int(secs)}s", self.font_small, BLACK, 70, stats_y + 80)
            self.draw_text(f"Max Wait Time: {max(self.wait_times):.2f} min", self.font_small, BLACK, 70, stats_y + 110)
            self.draw_text(f"Min Wait Time: {min(self.wait_times):.2f} min", self.font_small, BLACK, 70, stats_y + 140)

        # Draw moviegoers visualization
        moviegoer_y = 150
        for i, moviegoer in enumerate(theater.moviegoers[:30]):  # Display first 30
            x = 900 + (i % 10) * 40
            y = moviegoer_y + (i // 10) * 40
            self.draw_moviegoer(moviegoer, x, y)

        # Draw legend
        legend_y = 620
        self.draw_text("Legend:", self.font_medium, BLACK, 900, legend_y)
        pygame.draw.circle(self.screen, BLUE, (920, legend_y + 45), 6)
        self.draw_text("Waiting at Cashier", self.font_small, BLACK, 935, legend_y + 38)

        pygame.draw.circle(self.screen, YELLOW, (920, legend_y + 75), 6)
        self.draw_text("Being Served", self.font_small, BLACK, 935, legend_y + 68)

        pygame.draw.circle(self.screen, RED, (920, legend_y + 105), 6)
        self.draw_text("Waiting at Usher", self.font_small, BLACK, 935, legend_y + 98)

        pygame.draw.circle(self.screen, GREEN, (920, legend_y + 135), 6)
        self.draw_text("Waiting for Food", self.font_small, BLACK, 935, legend_y + 128)

        pygame.draw.circle(self.screen, DARK_GREEN, (920, legend_y + 165), 6)
        self.draw_text("Completed", self.font_small, BLACK, 935, legend_y + 158)

        pygame.display.flip()
        self.clock.tick(FPS)

        return self.simulation_running

def go_to_movies(env, moviegoer, theater, visualizer):
    arrival_time = env.now
    moviegoer.arrival_time = arrival_time

    # Purchase ticket
    moviegoer.state = MoviegoerState.WAITING_AT_CASHIER
    with theater.cashier.request() as request:
        yield request
        moviegoer.state = MoviegoerState.BUYING_TICKET
        yield env.process(theater.purchase_ticket(moviegoer))

    # Check ticket
    moviegoer.state = MoviegoerState.WAITING_AT_USHER
    with theater.usher.request() as request:
        yield request
        moviegoer.state = MoviegoerState.CHECKING_TICKET
        yield env.process(theater.check_ticket(moviegoer))

    # Buy food (50% chance)
    if random.choice([True, False]):
        moviegoer.state = MoviegoerState.WAITING_AT_SERVER
        with theater.server.request() as request:
            yield request
            moviegoer.state = MoviegoerState.BUYING_FOOD
            moviegoer.buying_food = True
            yield env.process(theater.sell_food(moviegoer))

    moviegoer.state = MoviegoerState.DONE
    wait_time = env.now - arrival_time
    moviegoer.wait_time = wait_time
    visualizer.wait_times.append(wait_time)

def run_theater(env, num_cashiers, num_servers, num_ushers, visualizer):
    theater = Theater(env, num_cashiers, num_servers, num_ushers)
    
    # Initial moviegoers
    for moviegoer_id in range(3):
        moviegoer = Moviegoer(moviegoer_id, env)
        theater.moviegoers.append(moviegoer)
        env.process(go_to_movies(env, moviegoer, theater, visualizer))

    moviegoer_id = 3
    while True:
        yield env.timeout(0.20)
        moviegoer = Moviegoer(moviegoer_id, env)
        theater.moviegoers.append(moviegoer)
        env.process(go_to_movies(env, moviegoer, theater, visualizer))
        visualizer.total_moviegoers = moviegoer_id + 1
        moviegoer_id += 1

def get_user_input():
    print("Theater Simulation Setup")
    print("-" * 40)
    
    while True:
        try:
            num_cashiers = int(input("Input # of cashiers working: "))
            num_servers = int(input("Input # of servers working: "))
            num_ushers = int(input("Input # of ushers working: "))
            
            if num_cashiers > 0 and num_servers > 0 and num_ushers > 0:
                return [num_cashiers, num_servers, num_ushers]
            else:
                print("Please enter positive numbers only.")
        except ValueError:
            print("Could not parse input. Please enter valid integers.")
            print("Using default values: 1 cashier, 1 server, 1 usher")
            return [1, 1, 1]

def main():
    random.seed(42)
    num_cashiers, num_servers, num_ushers = get_user_input()

    visualizer = SimulationVisualizer(SCREEN_WIDTH, SCREEN_HEIGHT)

    env = simpy.Environment()
    env.process(run_theater(env, num_cashiers, num_servers, num_ushers, visualizer))

    # Run simulation with visualization
    simulation_time = 0
    try:
        while simulation_time < 90 and visualizer.simulation_running:
            env.step()
            if not visualizer.update_display(env, env._queue[0].proc.gi_frame.f_locals.get('theater', None) if env._queue else None, num_cashiers, num_servers, num_ushers):
                break
            simulation_time = env.now
    except:
        # Fallback: run simulation without live updates
        env.run(until=90)
        visualizer.wait_times = []

    # Display final statistics
    if visualizer.wait_times:
        mins, secs = divmod(statistics.mean(visualizer.wait_times), 1)
        secs = int(secs * 60)
        print(f"\nSimulation Complete!")
        print(f"The average wait time is {int(mins)} minutes and {secs} seconds.")
        print(f"Total moviegoers: {visualizer.total_moviegoers}")
    
    pygame.quit()

if __name__ == "__main__":
    main()
